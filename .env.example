# Trading Journal App - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to GitHub

# SUPABASE
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# GITHUB OAUTH
VITE_GITHUB_CLIENT_ID=your-github-client-id
VITE_GITHUB_CLIENT_SECRET=your-github-client-secret

# REDDIT API (for community sentiment)
VITE_REDDIT_CLIENT_ID=your-reddit-client-id
VITE_REDDIT_CLIENT_SECRET=your-reddit-client-secret
VITE_REDDIT_USER_AGENT=TradingJournal/1.0 (by YourRedditUsername)

# STOCKTWITS (optional)
VITE_STOCKTWITS_API_KEY=your-stocktwits-api-key-optional

# MARKET DATA (choose one or more)
VITE_IEX_CLOUD_API_KEY=your-iex-api-key-optional
VITE_ALPACA_API_KEY=your-alpaca-api-key-optional

# ENVIRONMENT
NODE_ENV=development
VITE_APP_URL=http://localhost:5173

# GITHUB BACKUPS (optional)
VITE_GITHUB_REPO_OWNER=your-username
VITE_GITHUB_REPO_NAME=trading-journal-backups
VITE_GITHUB_TOKEN=your-personal-access-token
